{
  "db_name": "SQLite",
  "query": "\n            SELECT\n            md.*,\n            COALESCE(AVG(cs.read), 0) AS \"per_read: f64\",\n                                  COALESCE(\n                                      MAX(cs.last_read),\n                                  0\n        ) AS \"last_read: i64\"\n        FROM manga_details md\n        LEFT JOIN chapter_state cs\n        ON cs.source_id = md.source_id\n        AND cs.manga_id = md.id\n        WHERE md.source_id = ?1 AND md.id = ?2\n        GROUP BY md.source_id, md.id\n        ",
